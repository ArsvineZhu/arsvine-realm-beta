# Core
# Server port (default: 3000).
PORT=3000
# Canonical site URL used by sitemap, RSS, robots, Open Graph, and canonical tags.
NEXT_PUBLIC_SITE_URL=https://arsvine.com

# Public
# Optional telemetry provider. Supported value: vercel. Unset disables telemetry.
# NEXT_PUBLIC_TELEMETRY_PROVIDER=vercel
# Public CDN base for `realm/...` and `shared/...` assets.
NEXT_PUBLIC_CDN_BASE=https://cdn.arsvine.com

# Content
# Private content repository owner.
# GITHUB_OWNER=ArsvineZhu
# Private content repository name.
# GITHUB_REPO=arsvine-content
# Content repository branch.
# GITHUB_BRANCH=main
# Server-side GitHub token for private content reads.
# GITHUB_READ_TOKEN=github_pat_xxx

# Security
# Server-side signing secret for protected post access grants.
# ACCESS_GRANT_SECRET=replace-with-a-random-long-string
# Server-side TOTP groups JSON map.
# TOTP_GROUPS_JSON={"friends-a":{"current":"JBSWY3DPEHPK3PXP","period":30,"digits":6,"window":1}}
# Secret for ISR revalidation endpoints.
# REVALIDATE_SECRET=replace-with-a-random-long-string
# Trust `X-Forwarded-For` when revalidation endpoints run behind a trusted proxy.
# TRUST_PROXY=1

# Infra
# Optional Upstash Redis REST URL for distributed rate limiting.
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# Optional Upstash Redis REST token for distributed rate limiting.
# UPSTASH_REDIS_REST_TOKEN=your-token
# Private COS bucket for versioned asset catalogs.
# COS_PRIVATE_BUCKET=your-private-bucket
# Private COS bucket region.
# COS_PRIVATE_REGION=ap-hongkong
# Server-side COS SecretId.
# COS_SECRET_ID=AKIDxxx
# Server-side COS SecretKey.
# COS_SECRET_KEY=xxxx
# Optional prefix inside the private COS bucket before `realm/catalog/...`.
# COS_PRIVATE_CATALOG_PREFIX=

# Tweets Dev
# Enable synthetic tweet archive data in development.
# TWEETS_STRESS_TEST=1
# Synthetic tweet archive: number of years.
# TWEETS_STRESS_YEARS=6
# Synthetic tweet archive: months per year.
# TWEETS_STRESS_MONTHS_PER_YEAR=12
# Synthetic tweet archive: tweets per month.
# TWEETS_STRESS_TWEETS_PER_MONTH=24

# Advanced
# Enable `@next/bundle-analyzer` when set to `true`.
# ANALYZE=true
# Optional custom Next.js build output directory.
# NEXT_BUILD_DIR=.next
