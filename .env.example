# Server port (default: 3000)
PORT=3000

# Your site URL (used for sitemap and RSS generation)
NEXT_PUBLIC_SITE_URL=https://example.com

# Umami analytics (optional)
# Set both to enable the analytics script in <Head>. Leave unset to skip injection.
# NEXT_PUBLIC_UMAMI_SRC=https://your-umami-host/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id

# Server-side stats persistence file. Default: .stats.json in project root.
# Use an absolute path if your runtime user lacks write access to the project dir.
# STATS_FILE=/var/lib/portfolio/stats.json
