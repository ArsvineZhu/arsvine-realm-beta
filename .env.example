# Server port (default: 3000)
PORT=3000

# Your site URL (used for sitemap and RSS generation)
NEXT_PUBLIC_SITE_URL=https://example.com

# Umami analytics (optional)
# Set NEXT_PUBLIC_UMAMI_SRC to enable the analytics script in <Head>.
# Cloud-hosted Umami uses https://cloud.umami.is/script.js — self-hosted uses your own URL.
# NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id
# Restrict tracking to these domains; leave unset to track everywhere the script loads.
# Comma-separated list, no protocol. Localhost / preview deployments are skipped automatically.
# NEXT_PUBLIC_UMAMI_DOMAINS=your-domain.com,www.your-domain.com

# Vercel Analytics & Speed Insights
# Automatically enabled when deployed on Vercel (no env vars required).
# In local dev / non-Vercel deployments the scripts stay silent.

# Media CDN base URL (Tencent COS Hong Kong bucket `arsvine-cdn`, served via cdn.arsvine.com).
# Consumed by data/music.ts (and future post images). When unset, the music player falls
# back to /music/ under /public so local dev keeps working without the COS bucket.
# NEXT_PUBLIC_MEDIA_CDN=https://cdn.arsvine.com

# Private tweets repository (server-side only; do not use NEXT_PUBLIC_ prefix)
# TWEETS_GITHUB_OWNER=ArsvineZhu
# TWEETS_GITHUB_REPO=arsvine-tweets
# TWEETS_GITHUB_BRANCH=main
# TWEETS_GITHUB_TOKEN=github_pat_xxx

# On-demand ISR revalidation secret for /api/revalidate
# REVALIDATE_SECRET=replace-with-a-random-long-string

# Private content repository for the Web-only admin/blog system (server-side only)
# GITHUB_OWNER=ArsvineZhu
# GITHUB_REPO=arsvine-content
# GITHUB_BRANCH=main
# GITHUB_READ_TOKEN=github_pat_xxx
#
# Signed access grants for protected posts. Use a long random string.
# ACCESS_GRANT_SECRET=replace-with-a-random-long-string
#
# TOTP groups JSON map for protected post access.
# Example:
# TOTP_GROUPS_JSON={"friends-a":{"current":"JBSWY3DPEHPK3PXP","period":30,"digits":6,"window":1}}

# Dev-only tweets stress preview. When enabled, /{locale}/tweets renders generated data
# instead of fetching the private tweets repository.
# TWEETS_STRESS_TEST=1
# TWEETS_STRESS_YEARS=6
# TWEETS_STRESS_MONTHS_PER_YEAR=12
# TWEETS_STRESS_TWEETS_PER_MONTH=24

# Upstash Redis for /api/protected-verify rate limiting (Vercel Marketplace integration).
# 不配置时降级为 process-local Map，单实例准确，多实例不可靠 —— 生产部署务必接入。
# 集成 Upstash 后 Vercel 会自动注入这两个变量；本地手动配置即可。
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
