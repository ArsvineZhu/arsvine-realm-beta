# Server port (default: 3000)
PORT=3000

# Your site URL (used for sitemap and RSS generation)
NEXT_PUBLIC_SITE_URL=https://example.com

# Umami analytics (optional)
# Set NEXT_PUBLIC_UMAMI_SRC to enable the analytics script in <Head>.
# Cloud-hosted Umami uses https://cloud.umami.is/script.js — self-hosted uses your own URL.
# NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id
# Restrict tracking to these domains; leave unset to track everywhere the script loads.
# Comma-separated list, no protocol. Localhost / preview deployments are skipped automatically.
# NEXT_PUBLIC_UMAMI_DOMAINS=your-domain.com,www.your-domain.com

# Vercel Analytics & Speed Insights
# Automatically enabled when deployed on Vercel (no env vars required).
# In local dev / non-Vercel deployments the scripts stay silent.

# Media CDN base URL (Tencent COS Hong Kong bucket `arsvine-cdn`, served via cdn.arsvine.com).
# Consumed by data/music.ts (and future post images). When unset, the music player falls
# back to /music/ under /public so local dev keeps working without the COS bucket.
# NEXT_PUBLIC_MEDIA_CDN=https://cdn.arsvine.com
